{
  "navigationFallback": {
    "rewrite": "/index.html"
  },
  "mimeTypes": {
    ".md": "text/markdown; charset=utf-8",
    ".json": "application/json; charset=utf-8",
    ".js": "text/javascript; charset=utf-8"
  },
  "globalHeaders": {
    "cache-control": "no-cache"
  },
  "responseOverrides": {
    "404": {
      "rewrite": "/index.html"
    }
  }
}
